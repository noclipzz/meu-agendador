generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                            String                 @id @default(cuid())
  name                          String
  slug                          String                 @unique
  ownerId                       String                 @unique
  createdAt                     DateTime               @default(now())
  logoUrl                       String?                @default("")
  openTime                      String                 @default("09:00")
  closeTime                     String                 @default("18:00")
  lunchStart                    String                 @default("12:00")
  lunchEnd                      String                 @default("13:00")
  interval                      Int                    @default(30)
  workDays                      String                 @default("1,2,3,4,5")
  monthlyGoal                   Decimal                @default(5000)
  whatsappMessage               String?                @default("Olá {nome}, recebemos seu agendamento para *{servico}* em {dia} às {hora}.\n\nResponda *Sim* para Confirmar ou *Não* para Cancelar.")
  notificationEmail             String?
  facebookUrl                   String?                @default("")
  instagramUrl                  String?                @default("")
  address                       String?
  cep                           String?
  city                          String?
  cnpj                          String?
  complement                    String?
  neighborhood                  String?
  number                        String?
  phone                         String?
  state                         String?
  aliquotaServico               Decimal?               @default(0)
  certificadoA1Url              String?
  certificadoSenha              String?
  codigoServico                 String?
  inscricaoMunicipal            String?
  naturezaOperacao              Int?                   @default(1)
  regimeTributario              Int?                   @default(1)
  creditCardTax                 Decimal?               @default(0)
  debitCardTax                  Decimal?               @default(0)
  evolutionApiKey               String?
  evolutionServerUrl            String?
  whatsappInstanceId            String?
  whatsappStatus                String?                @default("DISCONNECTED")
  whatsappQrCode                String?
  whatsappCancelPromptMessage   String?                @default("⚠️ *Confirmação de Cancelamento*\n\n{nome}, você deseja realmente *CANCELAR* seu horário de *{servico}*?\n\nResponda *SIM* para confirmar o cancelamento definitivo.")
  whatsappCancelRevertMessage   String?                @default("Entendido! Mantivemos seu agendamento como *Pendente*. Caso deseje confirmar, digite *Sim*.")
  whatsappCancelSuccessMessage  String?                @default("❌ *Agendamento Cancelado*\n\nSeu agendamento foi cancelado com sucesso.")
  whatsappConfirmMessage        String?                @default("✅ *Agendamento Confirmado!*\n\n{nome}, seu horário para *{servico}* está garantido. Até lá!")
  whatsappWaitingListMessage    String?                @default("Olá {nome}, uma vaga surgiu para o dia {dia}! 🎉\n\nToque no link abaixo para garantir seu horário:\n{link}")
  corporateName                 String?
  coraAccessToken               String?
  coraClientId                  String?
  coraRefreshToken              String?
  coraTokenExpiry               DateTime?
  whatsappPaymentSuccessMessage String?                @default("✅ *Pagamento Confirmado!*\n\nOlá {nome}, recebemos seu pagamento de *{valor}* referente a *{descricao}*.\n\nObrigado!")
  inssTax                       Decimal?               @default(0)
  coraDiscountRate              Decimal?               @default(0.0)
  coraFineRate                  Decimal?               @default(2.0)
  coraInterestRate              Decimal?               @default(1.0)
  coraCertUrl                   String?
  coraKeyUrl                    String?
  signatureUrl                  String?                @default("")
  legalRepresentative           String?
  notificationSettings          Json?                  @default("{}")
  cnae                          String?
  fiscalPadraoDesc              String?
  issRetidoTomador              Boolean?               @default(false)
  itemListaServico              String?
  codigoNbs                     String?
  codigoTributacao              String?
  cofinsTax                     Decimal?               @default(0)
  construcaoCivil               Boolean?               @default(false)
  csllTax                       Decimal?               @default(0)
  descontarDeducoes             Boolean?               @default(false)
  descontarImpostos             Boolean?               @default(false)
  irTax                         Decimal?               @default(0)
  pisTax                        Decimal?               @default(0)
  financeAuxiliaries            Json?                  @default("{}")
  aiBotName                     String?                @default("Noclip")
  aiEnabled                     Boolean?               @default(false)
  aiSystemPrompt                String?
  aiFaq                         String?
  businessBranch                String?
  onboardingCompleted           Boolean?               @default(false)
  siteColor                     String?                @default("#3b82f6")
  customSchedule                Json?                  @default("{}")
  mercadopagoAccessToken        String?
  mercadopagoPublicKey          String?

  // Asaas Integration
  asaasApiKey                   String?
  asaasSubaccountId             String?
  asaasWalletId                 String?
  asaasBankCode                 String?
  asaasBankAgency               String?
  asaasBankAccount              String?
  asaasBankAccountDigit         String?

  vitrineSettings               Json?                  @default("{}")
  bankAccounts                  BankAccount[]
  blockedDates                  BlockedDate[]
  bookings                      Booking[]
  clients                       Client[]
  consentTerms                  ConsentTerm[]
  expenses                      Expense[]
  formTemplates                 FormTemplate[]
  integrationLogs               IntegrationLog[]
  invoices                      Invoice[]
  orders                        Order[]
  posts                         OrganizationPost[]
  products                      Product[]
  professionals                 Professional[]
  professionalLocations         ProfessionalLocation[]
  routes                        Route[]
  services                      Service[]
  suppliers                     Supplier[]
  teamMembers                   TeamMember[]
  vitrineProducts               VitrineProduct[]
  waitingList                   WaitingList[]
  chatSessions                  WhatsAppChatSession[]
}

model OrganizationPost {
  id         String   @id @default(cuid())
  title      String
  content    String
  type       String   @default("AVISO")
  imageUrl   String?
  authorId   String?
  authorName String?
  companyId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id          String  @id @default(cuid())
  email       String  @unique
  role        String  @default("PROFESSIONAL")
  companyId   String
  clerkUserId String? @unique
  permissions Json?
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Professional {
  id            String                @id @default(cuid())
  name          String
  photoUrl      String?
  phone         String?
  color         String                @default("#3b82f6")
  companyId     String
  userId        String?               @unique
  email         String?
  address       String?
  birthDate     String?
  cep           String?
  city          String?
  complement    String?
  cpf           String?
  createdAt     DateTime              @default(now())
  neighborhood  String?
  notes         String?
  number        String?
  rg            String?
  state         String?
  status        String                @default("ATIVO")
  updatedAt     DateTime              @default(now()) @updatedAt
  maritalStatus String?
  signatureUrl  String?
  attachments   Attachment[]
  bookings      Booking[]
  company       Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  locations     ProfessionalLocation?
  routes        Route[]
  waitingList   WaitingList[]
  services      Service[]             @relation("ProfessionalToService")
}

model Service {
  id            String           @id @default(cuid())
  name          String
  description   String?
  price         Decimal
  duration      Int
  companyId     String
  commission    Int              @default(0)
  imageUrl      String?
  bookings      Booking[]
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products      ServiceProduct[]
  waitingList   WaitingList[]
  professionals Professional[]   @relation("ProfessionalToService")
}

model Expense {
  id             String       @id @default(cuid())
  description    String
  value          Decimal
  category       String?
  dueDate        DateTime
  companyId      String
  paidAt         DateTime?
  paymentMethod  String?
  paymentAccount String?
  costCenter     String?
  nfe            String?
  notes          String?
  supplierId     String?
  status         String       @default("PENDENTE")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  frequency      String?      @default("ONCE")
  createdBy      String?
  updatedBy      String?
  bankAccountId  String?
  bankAccount    BankAccount? @relation(fields: [bankAccountId], references: [id])
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier       Supplier?    @relation(fields: [supplierId], references: [id])
}

model Invoice {
  id            String       @id @default(cuid())
  description   String
  value         Decimal
  method        String?
  status        String       @default("PENDENTE")
  dueDate       DateTime
  paidAt        DateTime?
  bookingId     String?      @unique
  clientId      String?
  companyId     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  cardTax       Decimal?     @default(0)
  netValue      Decimal?     @default(0)
  bankUrl       String?
  gatewayId     String?      @unique
  pixCopyPaste  String?
  pixQrCode     String?
  nfeNumber     String?
  nfeProtocol   String?
  nfeStatus     String?
  nfeUrl        String?
  bankAccountId String?
  costCenter    String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
  booking       Booking?     @relation(fields: [bookingId], references: [id])
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Booking {
  id             String        @id @default(cuid())
  date           DateTime
  customerName   String
  customerPhone  String?
  userId         String?
  clientId       String?
  serviceId      String?
  professionalId String?
  companyId      String
  location       String?
  type           String        @default("CLIENTE")
  reminderSent   Boolean       @default(false)
  status         String        @default("PENDENTE")
  description    String?
  client         Client?       @relation(fields: [clientId], references: [id])
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  professional   Professional? @relation(fields: [professionalId], references: [id])
  service        Service?      @relation(fields: [serviceId], references: [id])
  invoice        Invoice?
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime
  reason    String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
}

model Subscription {
  id                        String    @id @default(cuid())
  userId                    String    @unique
  plan                      String?
  status                    String    @default("INACTIVE")
  stripeCustomerId          String?   @unique
  stripeSubscriptionId      String?   @unique
  stripePriceId             String?
  expiresAt                 DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  cancelAtPeriodEnd         Boolean   @default(false)
  extraUsersCount           Int       @default(0)
  hasBoletoModule           Boolean   @default(false)
  hasNfeModule              Boolean   @default(false)
  hasDigitalSignatureModule Boolean   @default(false)
  hasTrackingModule         Boolean   @default(false)
  hasAiReceptionModule      Boolean   @default(false)
  hasMercadoPagoModule      Boolean   @default(false)
}

model Client {
  id                String        @id @default(cuid())
  name              String
  phone             String?
  email             String?
  cpf               String?
  rg                String?
  birthDate         String?
  cep               String?
  address           String?
  city              String?
  notes             String?
  status            String        @default("ATIVO")
  companyId         String
  createdAt         DateTime      @default(now())
  complement        String?
  neighborhood      String?
  number            String?
  state             String?
  maritalStatus     String?
  photoUrl          String?
  clientType        String        @default("FISICA")
  cnpj              String?
  inscricaoEstadual String?
  attachments       Attachment[]
  bookings          Booking[]
  company           Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  consentTerms      ConsentTerm[]
  formEntries       FormEntry[]
  invoices          Invoice[]
  routePoints       RoutePoint[]
}

model Attachment {
  id             String        @id @default(cuid())
  name           String
  url            String
  type           String
  clientId       String?
  createdAt      DateTime      @default(now())
  professionalId String?
  size           Int           @default(0)
  client         Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

model Product {
  id               String            @id @default(cuid())
  name             String
  quantity         Decimal           @default(0)
  unit             String            @default("UN")
  minStock         Decimal           @default(5)
  costPrice        Decimal?          @default(0)
  companyId        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  description      String?
  imageUrl         String?
  price            Decimal?          @default(0)
  category         String?
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  batches          ProductBatch[]
  usedInServices   ServiceProduct[]
  logs             StockLog[]
  supplierProducts SupplierProduct[]
}

model ProductBatch {
  id         String    @id @default(cuid())
  productId  String
  quantity   Decimal
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
  costPrice  Decimal?
  totalCost  Decimal?
  supplierId String?
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
}

model StockLog {
  id         String    @id @default(cuid())
  productId  String
  quantity   Decimal
  oldStock   Decimal
  newStock   Decimal
  type       String
  reason     String?
  createdAt  DateTime  @default(now())
  costPrice  Decimal?
  totalCost  Decimal?
  supplierId String?
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
}

model ServiceProduct {
  id        String  @id @default(cuid())
  serviceId String
  productId String
  amount    Decimal
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, productId])
}

model FormTemplate {
  id               String      @id @default(cuid())
  name             String
  description      String?
  fields           Json
  companyId        String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  requireSignature Boolean     @default(false)
  entries          FormEntry[]
  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model WaitingList {
  id             String        @id @default(cuid())
  customerName   String
  customerPhone  String
  preferences    String?
  status         String        @default("ATIVO")
  serviceId      String?
  professionalId String?
  companyId      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  desiredDate    DateTime?
  customerEmail  String?
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  professional   Professional? @relation(fields: [professionalId], references: [id])
  service        Service?      @relation(fields: [serviceId], references: [id])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model UserNotificationPref {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     Boolean  @default(true)
  whatsapp  Boolean  @default(true)
  push      Boolean  @default(true)
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  settings  Json?    @default("{}")
}

model FormEntry {
  id              String       @id @default(cuid())
  data            Json
  templateId      String
  clientId        String
  companyId       String
  filledBy        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  clientIp        String?
  clientUserAgent String?
  signatureUrl    String?
  signedAt        DateTime?
  status          String       @default("PENDENTE")
  client          Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  template        FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Supplier {
  id            String            @id @default(cuid())
  name          String
  corporateName String?
  cnpj          String?
  phone         String?
  email         String?
  cep           String?
  address       String?
  number        String?
  complement    String?
  neighborhood  String?
  city          String?
  state         String?
  notes         String?
  status        String            @default("ATIVO")
  companyId     String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  expenses      Expense[]
  batches       ProductBatch[]
  stockLogs     StockLog[]
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products      SupplierProduct[]
}

model SupplierProduct {
  id         String   @id @default(cuid())
  supplierId String
  productId  String
  price      Decimal  @default(0)
  sku        String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
}

model BankAccount {
  id        String    @id @default(cuid())
  name      String
  balance   Decimal   @default(0)
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  invoices  Invoice[]
}

model ConsentTerm {
  id              String    @id @default(cuid())
  title           String
  content         String
  status          String    @default("PENDENTE")
  signatureUrl    String?
  clientIp        String?
  clientUserAgent String?
  signedAt        DateTime?
  clientId        String
  companyId       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ProfessionalLocation {
  id             String       @id @default(cuid())
  professionalId String       @unique
  companyId      String
  latitude       Float
  longitude      Float
  accuracy       Float?
  lastUpdate     DateTime     @default(now())
  status         String       @default("ONLINE")
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([companyId])
}

model IntegrationLog {
  id           String   @id @default(cuid())
  companyId    String?
  service      String
  type         String
  status       String
  endpoint     String?
  identifier   String?
  payload      Json?
  response     Json?
  errorMessage String?
  createdAt    DateTime @default(now())
  company      Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model WhatsAppChatSession {
  id        String                @id @default(cuid())
  companyId String
  remoteJid String
  status    String                @default("ACTIVE")
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  messages  WhatsAppChatMessage[]
  company   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, remoteJid, status])
}

model WhatsAppChatMessage {
  id         String              @id @default(cuid())
  sessionId  String
  role       String
  content    String?
  createdAt  DateTime            @default(now())
  toolCallId String?
  toolCalls  Json?
  session    WhatsAppChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model VitrineProduct {
  id               String      @id @default(cuid())
  name             String
  description      String?
  price            Decimal?    @default(0)
  unitValue        Int         @default(1)
  imageUrl         String?
  showInVitrine    Boolean     @default(false)
  showStock        Boolean     @default(false)
  deliveryDeadline String?
  shippingCost     Decimal?    @default(0)
  variations       Json?       @default("[]")
  quantity         Decimal     @default(0)
  companyId        String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  category         String?
  orderItems       OrderItem[]
  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Order {
  id             String       @id @default(cuid())
  customerName   String
  customerEmail  String?
  customerPhone  String
  deliveryMethod String
  addressInfo    Json?
  status         String       @default("PENDING")
  totalAmount    Decimal
  paymentId      String?      @unique
  paymentMethod  String?
  companyId      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  isPaid         Boolean      @default(false)
  paymentDetails Json?
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items          OrderItem[]
  routePoints    RoutePoint[]

  @@index([companyId])
}

model OrderItem {
  id               String         @id @default(cuid())
  orderId          String
  vitrineProductId String
  quantity         Int
  price            Decimal
  variation        Json?
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vitrineProduct   VitrineProduct @relation(fields: [vitrineProductId], references: [id])
}

model Route {
  id             String       @id @default(cuid())
  name           String       @default("Nova Rota")
  status         String       @default("PENDING")
  professionalId String
  companyId      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  points         RoutePoint[]

  @@index([professionalId])
  @@index([companyId])
}

model RoutePoint {
  id         String   @id @default(cuid())
  routeId    String
  orderId    String?
  clientId   String?
  label      String
  address    String?
  status     String   @default("PENDING")
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client?  @relation(fields: [clientId], references: [id])
  order      Order?   @relation(fields: [orderId], references: [id])
  route      Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
}
